# Supabase config — fill these in before running
VITE_SUPABASE_URL=https://your-supabase-url.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Redirect URL (OPTIONAL - app auto-detects from current domain)
# 
# If not set, the app will automatically use:
# - Local: https://localhost:5173/reset-password
# - Vercel: https://your-project.vercel.app/reset-password
# - Custom domain: https://yourdomain.com/reset-password
# 
# You can optionally set this to override auto-detection:
# VITE_REDIRECT_URL=https://localhost:5173/reset-password
# 
# For Vercel, set in Vercel Dashboard → Settings → Environment Variables:
# VITE_REDIRECT_URL=https://your-project.vercel.app/reset-password
